<button class="info-nav-toggle" id="osa-nav-toggle" aria-label="Meny">
  <svg class="nav-icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <g class="nav-hamburger">
      <line x1="3" y1="7"  x2="21" y2="7"  stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      <line x1="3" y1="12" x2="21" y2="12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      <line x1="3" y1="17" x2="21" y2="17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    </g>
    <g class="nav-close">
      <line x1="5" y1="5" x2="19" y2="19" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      <line x1="19" y1="5" x2="5"  y2="19" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    </g>
  </svg>
</button>

<nav class="osa-nav" id="osa-nav">
  <a href="#deltagare-section">Deltagare</a>
  <a href="#narvaro-section">Närvaro</a>
  <a href="#kontakt-section" data-section="kontakt-section">Kontakt</a>
  <a href="#days-section" data-section="days-section">Dagar</a>
  <a href="#accommodation-section" data-section="accommodation-section">Boende</a>
  <a href="#kost-section" data-section="kost-section">Kost</a>
  <a href="#more-section" data-section="more-section">Mer</a>
  <a href="#submit-section" data-section="submit-section">Skicka</a>
  <hr class="info-nav__rule" />
  <a href="{{baseUrl}}/">Framsidan</a>
  <a href="{{baseUrl}}/info">Info</a>
</nav>

<div class="info-nav-backdrop" id="osa-nav-backdrop"></div>

<div class="osa-wrap">
  <header class="site-header">
    <p class="site-header__date"><span id="couple-names"></span> - 22:a augusti.</p>
    <h1><img class="site-logo" src="{{baseUrl}}/brollopsspelen.png" alt="Bröllopsspelen" /></h1>
    <a class="site-header__contact" href="{{baseUrl}}/info#kontakt">Kontakta oss om du undrar något.</a><br/>
    <a class="site-header__contact" href="{{baseUrl}}/info">Frågor och svar.</a>
  </header>
  <p class="page-subtitle">Fyll i formuläret nedan för att anmäla dig och ev. sällskap.<br>Vi hoppas att <span data-s="du" data-p="ni">du</span> kan komma.</p>

  {{> divider}}

  <form class="osa-form" action="https://formspree.io/f/xeenydqz" method="POST">
    <input type="hidden" name="_subject" value="OSA — Bröllopsspelen" />
    <input type="hidden" name="_next" value="{{baseUrl}}/tack" />
    <input type="hidden" name="narvaro" id="attendance-input" value="" />

    <!-- Deltagare -->
    <div class="osa-section" id="deltagare-section">
      <p class="note">
        Ange namnen för varje person <span data-s="du" data-p="ni">du</span> anmäler.
        Anmäl även namn och ålder på de barn som följer med <span data-s="dig" data-p="er">dig</span>, t.ex. <em>Finn Lysvret, 1 år</em>.
      </p>
      <label for="deltagare">Ett namn per rad *</label>
      <textarea id="deltagare" name="deltagare" placeholder="Kal Andersson" required rows="2"></textarea>
      <a class="site-header__contact" href="{{baseUrl}}/info#barn-sallskap">Läs om barn och sällskap (+1)</a>
    </div>

    <!-- Närvaro -->
    {{> divider}}
    <div class="osa-section" id="narvaro-section">
      <div class="attendance">
        <button type="button" class="btn-choice btn-decline" id="btn-decline" disabled>
          <span data-s="Jag" data-p="Vi">Jag</span> kan tyvärr ej närvara
        </button>
        <button type="button" class="btn-choice btn-attend" id="btn-attend" disabled>
          <span data-s="Jag" data-p="Vi">Jag</span> kommer
        </button>
      </div>
    </div>

    <!-- Kontaktinformation -->
    <div class="osa-section form-reveal" id="kontakt-section">
      {{> divider}}
      <p class="section-title">Kontaktinformation</p>
      <p class="note">Ange kontaktuppgifter till <span data-s="dig" data-p="en av er">dig</span> så att vi kan nå <span data-s="dig" data-p="er">dig</span> vid behov.</p>
      <div class="field">
        <label for="telefon">Telefonnummer *</label>
        <input type="tel" id="telefon" name="telefon" required autocomplete="tel" />
      </div>
      <div class="field">
        <label for="epost">E-postadress *</label>
        <input type="email" id="epost" name="epost" required autocomplete="email" />
      </div>
    </div>

    <!-- Vilka dagar -->
    <div class="osa-section form-reveal" id="days-section">
      {{> divider}}
      <p class="section-title">Vilka dagar delar <span data-s="du" data-p="ni">du</span> med oss?</p>
      <p class="note">
      	Själva vigseln och <i>Bröllopsspelen</i> är under lördagen. Men vi vill gärna fira tillsammans hela helgen och välkomnar <span data-s="dig" data-p="er">dig</span> att vara med både fredag och söndag.<br>Även om det kan vara svårt att veta så här tidigt så hjälper det oss att planera på ett ungefär så höfta gärna till det, det går bra att ändra sig.
      </p>
      <details class="accordion">
        <summary>Läs mer om helgens schema...</summary>
        <div class="accordion__body">
          {{> info-om-helgen}}
        </div>
      </details>
      <div class="day-choices">
      	<label>Välj dagar</label>
        <label class="day-choice">
          <input type="checkbox" name="dagar" value="fredag" />
          <div class="day-choice__body">
            <strong>Fredag - 21 augusti</strong>
          </div>
        </label>
        <label class="day-choice">
          <input type="checkbox" name="dagar" value="lordag" checked />
          <div class="day-choice__body">
            <strong>Lördag - 22 augusti</strong>
          </div>
        </label>
        <label class="day-choice">
          <input type="checkbox" name="dagar" value="sondag" />
          <div class="day-choice__body">
            <strong>Söndag - 23 augusti</strong>
          </div>
        </label>
      </div>
    </div>

    <!-- Boende -->
    <div class="osa-section form-reveal" id="accommodation-section">
      {{> divider}}
      <p class="section-title">Boende</p>
      <div class="note">
      För er som har en bit att resa finns det flera alternativ för övernattning att välja på. Vi hjälper gärna till att ordna boende om <span data-s="du" data-p="ni">du</span> önskar detta.
    </div>
      <details class="accordion">
        <summary>Läs mer om boendealternativ</summary>
        <div class="accordion__body">
          {{> info-boende}}
        </div>
      </details>
      <label>Hur ordnar <span data-s="du" data-p="ni">du</span> boendet?</label>
      <div class="radio-choices">
        <label class="radio-choice">
          <input type="radio" name="boende" value="sjalv" required />
          <span><span data-s="Jag" data-p="Vi">Jag</span> löser boendet själv</span>
        </label>
        <label class="radio-choice">
          <input type="radio" name="boende" value="talt" />
          <span><span data-s="Jag" data-p="Vi">Jag</span>  kommer tälta på Mjällbo</span>
        </label>
        <label class="radio-choice">
          <input type="radio" name="boende" value="hjalp" />
          <span><span data-s="Jag" data-p="Vi">Jag</span>  önskar hjälp att ordna boende</span>
        </label>
      </div>
      <label>Pssst</label>
      <div class="day-choices">
        <label class="day-choice">
          <input type="checkbox" name="erbjuder-boende" value="ja" />
          <span><span data-s="Jag" data-p="Vi">Jag</span> kan erbjuda boende till andra gäster</span>
        </label>
      </div>
    </div>

    <!-- Kost -->
    <div class="osa-section form-reveal" id="kost-section">
      {{> divider}}
      <p class="section-title">Matönskemål</p>
      <div class="note">
      Mat under helgen kommer vi till viss del lösa tillsammans med knytis, och en viss del bjuder vi på.
      <br><br> All mat under helgen kommer vara vegetarisk 🌱, men inte nödvändigtvis vegansk, så anmäl gärna om <span data-s="du" data-p="ni">du</span> önskar detta, samt <span data-s="dina" data-p="era">dina</span> övriga allergier och önskemål gällande mat.
      </div>
      <details class="accordion">
        <summary>Läs mer om mat under helgen...</summary>
        <div class="accordion__body">
          {{> info-mat}}
        </div>
      </details>
      <div class="field">
        <label for="matonskemal">Allergier eller önskemål</label>
        <textarea id="matonskemal" name="matonskemal" placeholder="T.ex. glutenintolerans, veganskt…" rows="2"></textarea>
      </div>
    </div>

    <!-- Något mer -->
    <div class="osa-section form-reveal" id="more-section">
      {{> divider}}
      <p class="section-title">Något mer <span data-s="du" data-p="ni">du</span> vill att vi ska veta?</p>
      <div class="field">
        <textarea name="ovrigt" placeholder="Skriv gärna vad som helst…" rows="2"></textarea>
      </div>
    </div>

    <!-- Skicka -->
    <div class="form-reveal" id="submit-section">
      {{> divider}}
      <button type="submit">Skicka OSA</button>
    </div>

  </form>
</div>

<script>
  document.getElementById('couple-names').textContent = Math.random() < 0.5 ? 'Katrin ⚭ Viktor' : 'Viktor ⚭ Katrin';

  const textarea = document.getElementById('deltagare');
  const attendanceInput = document.getElementById('attendance-input');
  const btnDecline = document.getElementById('btn-decline');
  const btnAttend = document.getElementById('btn-attend');
  const kontaktSection = document.getElementById('kontakt-section');
  const daysSection = document.getElementById('days-section');
  const accommodationSection = document.getElementById('accommodation-section');
  const kostSection = document.getElementById('kost-section');
  const moreSection = document.getElementById('more-section');
  const submitSection = document.getElementById('submit-section');
  var osaNav = document.getElementById('osa-nav');
  let participantCount = 0;

  const dev = window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1';
  if (dev) {
    btnDecline.disabled = false;
    btnAttend.disabled = false;
    kontaktSection.classList.add('is-visible');
    daysSection.classList.add('is-visible');
    accommodationSection.classList.add('is-visible');
    kostSection.classList.add('is-visible');
    moreSection.classList.add('is-visible');
    submitSection.classList.add('is-visible');
    syncOsaNav();
  }

  function update() {
    const lines = textarea.value.split('\n').filter(function(l) { return l.trim().length > 0; });
    participantCount = lines.length;

    textarea.style.height = 'auto';
    textarea.style.height = textarea.scrollHeight + 'px';

    const hasName = participantCount > 0;
    btnDecline.disabled = !hasName;
    btnAttend.disabled = !hasName;

    const plural = participantCount > 1;
    document.querySelectorAll('[data-s]').forEach(function(el) {
      el.textContent = plural ? el.dataset.p : el.dataset.s;
    });
  }

  function selectAttendance(value) {
    attendanceInput.value = value;
    const attending = value === 'ja';
    btnDecline.classList.toggle('is-selected', !attending);
    btnAttend.classList.toggle('is-selected', attending);
    document.body.classList.toggle('attendance-declined', !attending);
    kontaktSection.classList.toggle('is-visible', attending);
    document.getElementById('telefon').required = attending;
    document.getElementById('epost').required = attending;
    document.querySelector('input[name="boende"]').required = attending;
    daysSection.classList.toggle('is-visible', attending);
    accommodationSection.classList.toggle('is-visible', attending);
    kostSection.classList.toggle('is-visible', attending);
    moreSection.classList.add('is-visible');
    submitSection.classList.add('is-visible');
    syncOsaNav();
    if (attending) {
      document.getElementById('telefon').focus();
    } else {
      moreSection.querySelector('textarea').focus();
    }
  }

  btnDecline.addEventListener('click', function() { selectAttendance('nej'); });
  btnAttend.addEventListener('click', function() { selectAttendance('ja'); });
  textarea.addEventListener('input', update);

  document.querySelector('.osa-form').addEventListener('submit', function() {
    var url = new URL('/tack', window.location.origin);
    url.searchParams.set('attendance', attendanceInput.value === 'ja' ? 'ja' : 'nej');
    url.searchParams.set('plural', participantCount > 1 ? '1' : '0');
    document.querySelector('input[name="_next"]').value = url.toString();
  });

  document.querySelectorAll('textarea:not(#deltagare)').forEach(function(ta) {
    ta.addEventListener('input', function() {
      this.style.height = 'auto';
      this.style.height = this.scrollHeight + 'px';
    });
  });

  var osaNavToggle = document.getElementById('osa-nav-toggle');
  var osaNavBackdrop = document.getElementById('osa-nav-backdrop');

  function closeOsaNav() {
    osaNav.classList.remove('is-open');
    osaNavToggle.classList.remove('is-open');
    osaNavBackdrop.classList.remove('is-visible');
  }

  osaNavToggle.addEventListener('click', function() {
    var open = osaNav.classList.toggle('is-open');
    osaNavToggle.classList.toggle('is-open', open);
    osaNavBackdrop.classList.toggle('is-visible', open);
  });

  osaNavBackdrop.addEventListener('click', closeOsaNav);

  osaNav.querySelectorAll('a').forEach(function(link) {
    link.addEventListener('click', closeOsaNav);
  });

  function syncOsaNav() {
    document.querySelectorAll('.form-reveal[id]').forEach(function(section) {
      var link = osaNav.querySelector('a[data-section="' + section.id + '"]');
      if (link) link.classList.toggle('is-visible', section.classList.contains('is-visible'));
    });
  }
</script>
