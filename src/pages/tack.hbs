<div class="osa-wrap tack-wrap">
  <header class="site-header">
    <p class="site-header__date"><span id="couple-names"></span> - 22:a augusti.</p>
    <h1><img class="site-logo" src="{{baseUrl}}/brollopsspelen.png" alt="Bröllopsspelen" /></h1>
  </header>

  {{> divider}}

  <div class="tack-body">
    <p class="tack-title" id="tack-title">Tack för din anmälan!</p>
    <img class="tack-rose" id="tack-rose" src="{{baseUrl}}/rose1.png" alt="" aria-hidden="true" />
    <p class="tack-text" id="tack-text"></p>
    <div class="tack-links" id="tack-links">
      <a href="{{baseUrl}}/">Tillbaka till framsidan</a>
      <a href="{{baseUrl}}/info" id="tack-link-info">Läs mer om helgen</a>
    </div>
    {{> divider}}
  </div>
</div>

<script>
  document.getElementById('couple-names').textContent = Math.random() < 0.5 ? 'Katrin ⚭ Viktor' : 'Viktor ⚭ Katrin';

  var params = new URLSearchParams(window.location.search);
  var attendance = params.get('attendance');
  var plural = params.get('plural') === '1';

  var din = plural ? 'er'  : 'din';
  var du  = plural ? 'ni'  : 'du';
  var dig = plural ? 'er'  : 'dig';

  if (attendance === 'ja') {
    document.getElementById('tack-title').textContent = 'Tack för ' + din + ' anmälan!';
    document.getElementById('tack-text').innerHTML =
      'Vi ser fram emot att fira tillsammans.<br>' +
      'Om ' + du + ' har frågor är ' + du + ' alltid välkommen att höra av ' + dig + '.';
  } else if (attendance === 'nej') {
    document.getElementById('tack-title').textContent = 'Å, det var tråkigt!';
    document.getElementById('tack-rose').style.display = 'none';
    document.getElementById('tack-text').innerHTML =
      'Vi förstår att det inte alltid går.<br>' +
      'Hoppas ' + du + ' har det bra och att vi ses vid ett annat tillfälle.';
    document.getElementById('tack-link-info').style.display = 'none';
  }
</script>
