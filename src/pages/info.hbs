<button class="info-nav-toggle" id="nav-toggle" aria-label="Meny">
  <span></span>
  <span></span>
  <span></span>
</button>

<nav class="info-nav" id="info-nav">
  <a href="#valkomst">Välkommen</a>
  <a href="#vigsel">Vigsel</a>
  <a href="#middag">Middag & Fest</a>
  <a href="#boende">Boende</a>
  <a href="#bra-att-veta">Bra att veta</a>
  <a href="#kontakt">Kontakt</a>
  <hr class="info-nav__rule" />
  <a href="{{baseUrl}}/">Framsidan</a>
  <a href="{{baseUrl}}/osa">OSA</a>
</nav>

<div class="info-nav-backdrop" id="nav-backdrop"></div>

<div class="info">

  <header class="info-header">
    <h1>Katrin & Viktor</h1>
    <p class="info-header__date">Datum · Ort</p>
  </header>

  <section class="info-section" id="valkomst">
    <h2>Välkommen</h2>
    {{> info-valkomst}}
  </section>

  <section class="info-section" id="vigsel">
    <h2>Vigsel</h2>
    {{> info-vigsel}}
  </section>

  <section class="info-section" id="middag">
    <h2>Middag & Fest</h2>
    {{> info-middag}}
  </section>

  <div class="info-image">
    <img src="{{baseUrl}}/bg.jpg" alt="Platsen" />
  </div>

  <section class="info-section" id="boende">
    <h2>Boende</h2>
    {{> info-boende}}
  </section>

  <section class="info-section" id="bra-att-veta">
    <h2>Bra att veta</h2>
    {{> info-bra-att-veta}}
  </section>

  <section class="info-section" id="kontakt">
    <h2>Kontakt</h2>
    {{> info-kontakt}}
  </section>

</div>

<script>
  const toggle = document.getElementById('nav-toggle');
  const nav = document.getElementById('info-nav');
  const backdrop = document.getElementById('nav-backdrop');

  function close() {
    nav.classList.remove('is-open');
    toggle.classList.remove('is-open');
    backdrop.classList.remove('is-visible');
  }

  toggle.addEventListener('click', function () {
    const open = nav.classList.toggle('is-open');
    toggle.classList.toggle('is-open', open);
    backdrop.classList.toggle('is-visible', open);
  });

  backdrop.addEventListener('click', close);

  nav.querySelectorAll('a[href^="#"]').forEach(function (link) {
    link.addEventListener('click', close);
  });

  const sections = document.querySelectorAll('.info-section[id]');
  const navLinks = nav.querySelectorAll('a[href^="#"]');

  const observer = new IntersectionObserver(function (entries) {
    entries.forEach(function (entry) {
      if (entry.isIntersecting) {
        navLinks.forEach(function (l) { l.classList.remove('active'); });
        const active = nav.querySelector('a[href="#' + entry.target.id + '"]');
        if (active) active.classList.add('active');
      }
    });
  }, { rootMargin: '-30% 0px -60% 0px' });

  sections.forEach(function (s) { observer.observe(s); });
</script>
