<button class="info-nav-toggle" id="nav-toggle" aria-label="Meny">
  <svg class="nav-icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <g class="nav-hamburger">
      <line x1="3" y1="7"  x2="21" y2="7"  stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      <line x1="3" y1="12" x2="21" y2="12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      <line x1="3" y1="17" x2="21" y2="17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    </g>
    <g class="nav-close">
      <line x1="5" y1="5" x2="19" y2="19" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      <line x1="19" y1="5" x2="5"  y2="19" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    </g>
  </svg>
</button>

<nav class="info-nav" id="info-nav">
  <a href="#om-helgen">Om helgen</a>
  <a href="#valkomst">Välkommen</a>
  <a href="#vigsel">Vigsel</a>
  <a href="#middag">Middag & Fest</a>
  <a href="#boende">Boende</a>
  <a href="#bra-att-veta">Bra att veta</a>
  <a href="#kost">Mat</a>
  <a href="#barn-sallskap">Barn</a>
  <a href="#kontakt">Kontakt</a>
  <hr class="info-nav__rule" />
  <a href="{{baseUrl}}/">Framsidan</a>
  <a href="{{baseUrl}}/osa">Anmälan / OSA</a>
</nav>

<div class="info-nav-backdrop" id="nav-backdrop"></div>

<div class="info">

  <header class="site-header">
    <p class="site-header__date"><span id="couple-names"></span> - 22:a augusti.</p>
    <h1><img class="site-logo" src="{{baseUrl}}/brollopsspelen.png" alt="Bröllopsspelen" /></h1>
  </header>
  <p class="page-subtitle">Information inför bröllopet</p>

  <div class="warning-strip">
    <details class="accordion warning-accordion">
      <summary>Obs! Vi kan komma att ändra visa detaljer</summary>
      <div class="accordion__body">
        <p>All information på den här sidan är ännu inte bekräftad och kan komma att ändras. Datum och tider stämmer, men detaljer kring program, boende och praktikaliteter uppdateras löpande närmre bröllopet.</p>
        <p>Vi hör av oss med mer info när allt är satt — tack för tålamodet!</p>
      </div>
    </details>
  </div>


<section class="info-section" id="om-brollopsspelen">
<p>
  Vi är så glada att du vill komma och fira med oss.
  Här hittar du all information du behöver inför helgen...
  <br/>
  <br/>
</p>
  <h2>Ett lite annorlunda bröllop</h2>
  {{> info-om-brollopsspelen}}
</section>

<section class="info-section" id="platsen">
	<h2>Mjällbo gård</h2>
	{{> info-platsen}}
</section>

<section class="info-section" id="om-helgen">
	<h2>Om helgen</h2>
    {{> info-om-helgen}}
</section>



  <section class="info-section" id="kladsel">
    <h2>Klädsel och förberedelser</h2>
    {{> info-kladsel-och-forberedelser}}
  </section>

  <section class="info-section" id="mat">
    <h2>Mat</h2>
    {{> info-mat}}
  </section>

  <section class="info-section" id="boende">
    <h2>Boende</h2>
    {{> info-boende}}
  </section>

  <section class="info-section" id="resa">
    <h2>Resa och parkering</h2>
    {{> info-resa}}
  </section>



  <section class="info-section" id="barn-sallskap">
    <h2>Om barn och sällskap (+1)</h2>
    {{> info-barn-och-sallskap}}
  </section>

  <section class="info-section" id="kontakt">
    <h2>Kontakt</h2>
    {{> info-kontakt}}
  </section>

</div>

<script>
  document.getElementById('couple-names').textContent = Math.random() < 0.5 ? 'Katrin ⚭ Viktor' : 'Viktor ⚭ Katrin';

  const toggle = document.getElementById('nav-toggle');
  const nav = document.getElementById('info-nav');
  const backdrop = document.getElementById('nav-backdrop');

  function close() {
    nav.classList.remove('is-open');
    toggle.classList.remove('is-open');
    backdrop.classList.remove('is-visible');
  }

  toggle.addEventListener('click', function () {
    const open = nav.classList.toggle('is-open');
    toggle.classList.toggle('is-open', open);
    backdrop.classList.toggle('is-visible', open);
  });

  backdrop.addEventListener('click', close);

  nav.querySelectorAll('a[href^="#"]').forEach(function (link) {
    link.addEventListener('click', close);
  });

  const sections = document.querySelectorAll('.info-section[id]');
  const navLinks = nav.querySelectorAll('a[href^="#"]');

  const observer = new IntersectionObserver(function (entries) {
    entries.forEach(function (entry) {
      if (entry.isIntersecting) {
        navLinks.forEach(function (l) { l.classList.remove('active'); });
        const active = nav.querySelector('a[href="#' + entry.target.id + '"]');
        if (active) active.classList.add('active');
      }
    });
  }, { rootMargin: '-30% 0px -60% 0px' });

  sections.forEach(function (s) { observer.observe(s); });
</script>
